            "height": 50,
            "style": { "fill": "#451a03", "stroke": "#f59e0b", "strokeWidth": 2 }
          },
          {
            "id": "lcm-def-text",
            "type": "annotation",
            "position": [400, 285],
            "latex": "\\text{LCM}(a, b) = \\text{smallest number that is a multiple of both}",
            "anchor": "center",
            "style": { "fontSize": 18, "fill": "#fbbf24" }
          }
        ]
      },
