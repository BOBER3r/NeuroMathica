        "anchor": "center",
        "style": { "fontSize": 26, "fill": "#e2e8f0" }
      },
      {
        "id": "factor-def",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "factor-def-bg",
            "type": "geometricShape",
            "shape": "rectangle",
            "center": [400, 80],
            "width": 650,
            "height": 50,
            "style": { "fill": "#1e1b4b", "stroke": "#7c3aed", "strokeWidth": 2 }
          },
          {
            "id": "factor-def-text",
            "type": "annotation",
            "position": [400, 80],
            "latex": "a \\text{ is a factor of } b \\iff b \\div a \\text{ has no remainder}",
            "anchor": "center",
            "style": { "fontSize": 20, "fill": "#c4b5fd" }
          }
        ]
      },
      {
        "id": "multiple-def",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "multiple-def-bg",
            "type": "geometricShape",
            "shape": "rectangle",
            "center": [400, 145],
            "width": 650,
            "height": 50,
            "style": { "fill": "#172554", "stroke": "#3b82f6", "strokeWidth": 2 }
          },
          {
            "id": "multiple-def-text",
            "type": "annotation",
            "position": [400, 145],
            "latex": "b \\text{ is a multiple of } a \\iff b = a \\times n \\text{ for some whole } n",
            "anchor": "center",
            "style": { "fontSize": 20, "fill": "#93c5fd" }
          }
        ]
      },
      {
        "id": "gcf-def",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "gcf-def-bg",
            "type": "geometricShape",
            "shape": "rectangle",
            "center": [400, 215],
            "width": 650,
            "height": 50,
            "style": { "fill": "#052e16", "stroke": "#10b981", "strokeWidth": 2 }
          },
          {
            "id": "gcf-def-text",
            "type": "annotation",
            "position": [400, 215],
            "latex": "\\text{GCF}(a, b) = \\text{greatest number that divides both } a \\text{ and } b",
            "anchor": "center",
            "style": { "fontSize": 18, "fill": "#6ee7b7" }
          }
        ]
      },
      {
        "id": "lcm-def",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "lcm-def-bg",
            "type": "geometricShape",
