        "target": "acute-angle",
        "onUpdate": [
          {
            "source": "value",
            "target": "acute-angle",
            "property": "style.stroke",
            "transform": "toggleHighlight(#10b981, #34d399)"
          }
        ]
      },
      {
        "id": "click-right",
        "type": "click",
        "target": "right-angle",
        "onUpdate": [
