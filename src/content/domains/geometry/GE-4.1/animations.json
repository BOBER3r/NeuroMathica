  "symbol": {
    "id": "GE-4.1-symbol",
    "renderer": "svg",
    "viewBox": [0, 0, 800, 400],
    "background": "#0f172a",
    "objects": [
      {
        "id": "symbol-title",
        "type": "annotation",
        "position": [400, 30],
        "latex": "\\text{Angle Notation \\& Rules}",
        "anchor": "center",
        "style": { "fontSize": 26, "fill": "#e2e8f0" }
      },
      {
        "id": "notation-box",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "notation-bg",
            "type": "geometricShape",
            "shape": "rectangle",
            "center": [400, 80],
            "width": 650,
            "height": 50,
            "style": { "fill": "#1e1b4b", "stroke": "#7c3aed", "strokeWidth": 2 }
          },
          {
            "id": "notation-text",
            "type": "annotation",
            "position": [400, 80],
            "latex": "\\angle ABC \\text{ means the angle at vertex } B \\text{, with rays } BA \\text{ and } BC",
            "anchor": "center",
            "style": { "fontSize": 18, "fill": "#c4b5fd" }
          }
        ]
      },
      {
        "id": "comp-rule",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "comp-rule-bg",
            "type": "geometricShape",
            "shape": "rectangle",
            "center": [400, 145],
            "width": 650,
            "height": 50,
            "style": { "fill": "#052e16", "stroke": "#10b981", "strokeWidth": 2 }
          },
          {
            "id": "comp-rule-text",
            "type": "annotation",
            "position": [400, 145],
            "latex": "\\text{Complementary: } \\angle A + \\angle B = 90°",
            "anchor": "center",
            "style": { "fontSize": 20, "fill": "#6ee7b7" }
          }
        ]
      },
      {
        "id": "supp-rule",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "supp-rule-bg",
            "type": "geometricShape",
            "shape": "rectangle",
            "center": [400, 210],
            "width": 650,
            "height": 50,
            "style": { "fill": "#172554", "stroke": "#3b82f6", "strokeWidth": 2 }
          },
          {
            "id": "supp-rule-text",
            "type": "annotation",
            "position": [400, 210],
            "latex": "\\text{Supplementary: } \\angle A + \\angle B = 180°",
            "anchor": "center",
            "style": { "fontSize": 20, "fill": "#93c5fd" }
          }
        ]
      },
      {
        "id": "triangle-rule",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "triangle-rule-bg",
            "type": "geometricShape",
            "shape": "rectangle",
            "center": [400, 275],
            "width": 650,
            "height": 50,
            "style": { "fill": "#451a03", "stroke": "#f59e0b", "strokeWidth": 2 }
          },
          {
            "id": "triangle-rule-text",
            "type": "annotation",
            "position": [400, 275],
            "latex": "\\text{Triangle Angle Sum: } \\angle A + \\angle B + \\angle C = 180°",
            "anchor": "center",
            "style": { "fontSize": 20, "fill": "#fbbf24" }
          }
        ]
      },
      {
        "id": "full-rotation",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "full-rotation-bg",
            "type": "geometricShape",
            "shape": "rectangle",
            "center": [400, 340],
            "width": 650,
            "height": 50,
            "style": { "fill": "#1e293b", "stroke": "#94a3b8", "strokeWidth": 2 }
          },
          {
            "id": "full-rotation-text",
            "type": "annotation",
            "position": [400, 340],
            "latex": "\\text{Full rotation} = 360° \\quad \\text{Half turn} = 180° \\quad \\text{Quarter turn} = 90°",
            "anchor": "center",
            "style": { "fontSize": 18, "fill": "#e2e8f0" }
          }
        ]
      }
    ],
    "animations": [
      {
        "id": "symbol-reveal",
        "trigger": "stage-enter",
        "steps": [
          {
            "action": "fadeIn",
            "target": "notation-box",
            "duration": 0.5,
            "ease": "easeOutBack",
            "from": "left"
          },
          { "action": "wait", "duration": 0.2 },
          {
            "action": "fadeIn",
            "target": "comp-rule",
            "duration": 0.5,
            "ease": "easeOutBack",
            "from": "left"
          },
          {
            "action": "fadeIn",
            "target": "supp-rule",
            "duration": 0.5,
            "ease": "easeOutBack",
            "from": "left"
          },
          { "action": "wait", "duration": 0.3 },
          {
            "action": "fadeIn",
            "target": "triangle-rule",
            "duration": 0.6,
            "ease": "easeOutBack",
            "from": "left"
          },
          {
            "action": "highlight",
            "target": "triangle-rule",
            "duration": 1.0,
            "color": "#f59e0b",
            "pulse": true
          },
          {
            "action": "fadeIn",
            "target": "full-rotation",
            "duration": 0.5,
            "ease": "easeOutBack",
            "from": "left"
          }
        ]
      }
    ],
    "interactions": [
      {
        "id": "hover-notation",
        "type": "hover",
        "target": "notation-box",
        "onUpdate": [
          {
            "source": "value",
            "target": "notation-bg",
            "property": "style.strokeWidth",
            "transform": "hoverScale(2, 4)"
          }
        ]
      },
      {
        "id": "hover-comp",
        "type": "hover",
        "target": "comp-rule",
        "onUpdate": [
          {
            "source": "value",
            "target": "comp-rule-bg",
            "property": "style.strokeWidth",
            "transform": "hoverScale(2, 4)"
          }
        ]
      },
      {
        "id": "hover-supp",
        "type": "hover",
        "target": "supp-rule",
        "onUpdate": [
          {
            "source": "value",
            "target": "supp-rule-bg",
            "property": "style.strokeWidth",
            "transform": "hoverScale(2, 4)"
          }
        ]
      },
      {
        "id": "hover-triangle",
        "type": "hover",
        "target": "triangle-rule",
        "onUpdate": [
          {
            "source": "value",
            "target": "triangle-rule-bg",
            "property": "style.strokeWidth",
            "transform": "hoverScale(2, 4)"
          }
        ]
      }
    ]
  }
}
