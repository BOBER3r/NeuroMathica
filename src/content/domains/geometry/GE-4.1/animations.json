{
  "hook": {
    "id": "GE-4.1-hook",
    "renderer": "svg",
    "viewBox": [0, 0, 800, 400],
    "background": "#0f172a",
    "objects": [
      {
        "id": "title-text",
        "type": "annotation",
        "position": [400, 30],
        "latex": "\\text{Angles are everywhere}",
        "anchor": "center",
        "style": { "fontSize": 28, "fill": "#e2e8f0" },
        "opacity": 0
      },
      {
        "id": "clock-face",
        "type": "geometricShape",
        "shape": "circle",
        "center": [200, 200],
        "radius": 100,
        "style": { "fill": "#1e293b", "stroke": "#475569", "strokeWidth": 2 }
      },
      {
        "id": "clock-center",
        "type": "point",
        "position": [200, 200],
        "radius": 5,
        "style": { "fill": "#e2e8f0" }
      },
      {
        "id": "clock-12",
        "type": "annotation",
        "position": [200, 115],
        "latex": "12",
        "anchor": "center",
        "style": { "fontSize": 14, "fill": "#94a3b8" }
      },
      {
        "id": "clock-3",
        "type": "annotation",
        "position": [285, 200],
        "latex": "3",
        "anchor": "center",
        "style": { "fontSize": 14, "fill": "#94a3b8" }
      },
      {
        "id": "clock-6",
        "type": "annotation",
        "position": [200, 290],
        "latex": "6",
        "anchor": "center",
        "style": { "fontSize": 14, "fill": "#94a3b8" }
      },
      {
        "id": "clock-9",
        "type": "annotation",
        "position": [115, 200],
        "latex": "9",
        "anchor": "center",
        "style": { "fontSize": 14, "fill": "#94a3b8" }
      },
      {
        "id": "minute-hand",
        "type": "line",
        "from": [200, 200],
        "to": [200, 120],
        "style": { "stroke": "#e2e8f0", "strokeWidth": 2 }
      },
      {
        "id": "hour-hand",
        "type": "line",
        "from": [200, 200],
        "to": [270, 200],
        "style": { "stroke": "#7c3aed", "strokeWidth": 3 }
      },
      {
        "id": "clock-angle-arc",
        "type": "angle",
        "vertex": [200, 200],
        "ray1End": [200, 120],
        "ray2End": [270, 200],
        "showArc": true,
        "showMeasurement": true,
        "arcRadius": 35,
        "style": { "stroke": "#fbbf24", "strokeWidth": 2 },
        "opacity": 0
      },
      {
        "id": "clock-angle-label",
        "type": "annotation",
        "position": [200, 340],
        "latex": "3 \\text{ o'clock} = 90°",
        "anchor": "center",
        "style": { "fontSize": 22, "fill": "#fbbf24" },
        "opacity": 0
      },
      {
        "id": "pizza-slice",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "pizza-circle",
            "type": "geometricShape",
            "shape": "circle",
            "center": [550, 200],
            "radius": 80,
            "style": { "fill": "#f59e0b20", "stroke": "#f59e0b", "strokeWidth": 2 }
          },
          {
            "id": "pizza-cut-1",
            "type": "line",
            "from": [550, 200],
            "to": [630, 200],
            "style": { "stroke": "#f59e0b", "strokeWidth": 2 }
          },
          {
            "id": "pizza-cut-2",
            "type": "line",
            "from": [550, 200],
            "to": [590, 140],
            "style": { "stroke": "#f59e0b", "strokeWidth": 2 }
          },
          {
            "id": "pizza-angle",
            "type": "angle",
            "vertex": [550, 200],
            "ray1End": [630, 200],
            "ray2End": [590, 140],
            "showArc": true,
            "showMeasurement": true,
            "arcRadius": 30,
            "style": { "stroke": "#ef4444", "strokeWidth": 2 }
          }
        ]
      },
      {
        "id": "pizza-label",
        "type": "annotation",
        "position": [550, 340],
        "latex": "\\text{Pizza slice} = 45°",
        "anchor": "center",
        "style": { "fontSize": 22, "fill": "#f59e0b" },
        "opacity": 0
      }
    ],
    "animations": [
      {
        "id": "hook-intro",
        "trigger": "auto",
        "steps": [
          {
            "action": "fadeIn",
            "target": "title-text",
            "duration": 0.8,
            "ease": "easeInOut",
            "from": "top"
          },
          { "action": "wait", "duration": 0.5 },
          {
            "action": "fadeIn",
            "target": "clock-angle-arc",
            "duration": 0.6,
            "ease": "easeInOut"
          },
          {
            "action": "fadeIn",
            "target": "clock-angle-label",
            "duration": 0.5,
            "ease": "spring",
            "from": "scale"
          },
          { "action": "wait", "duration": 0.5 },
          {
            "action": "fadeIn",
            "target": "pizza-slice",
            "duration": 0.6,
            "ease": "easeOutBack",
            "from": "scale"
          },
          {
            "action": "fadeIn",
            "target": "pizza-label",
            "duration": 0.5,
            "ease": "spring",
            "from": "scale"
          }
        ]
      }
    ],
    "interactions": []
  },
  "spatial": {
    "id": "GE-4.1-spatial",
    "renderer": "svg",
    "viewBox": [0, 0, 800, 500],
    "background": "#0f172a",
    "objects": [
      {
        "id": "spatial-title",
        "type": "annotation",
        "position": [400, 25],
        "latex": "\\text{Interactive Protractor}",
        "anchor": "center",
        "style": { "fontSize": 22, "fill": "#e2e8f0" }
      },
      {
        "id": "protractor-arc",
        "type": "geometricShape",
        "shape": "circle",
        "center": [400, 280],
        "radius": 180,
        "style": { "fill": "#1e293b20", "stroke": "#475569", "strokeWidth": 2 }
      },
      {
        "id": "ray-fixed",
        "type": "line",
        "from": [400, 280],
        "to": [600, 280],
        "arrowHead": "end",
        "style": { "stroke": "#e2e8f0", "strokeWidth": 2 }
      },
      {
        "id": "ray-draggable-line",
        "type": "line",
        "from": [400, 280],
        "to": [550, 150],
        "arrowHead": "end",
        "style": { "stroke": "#7c3aed", "strokeWidth": 2 }
      },
      {
        "id": "angle-arc",
        "type": "angle",
        "vertex": [400, 280],
        "ray1End": [600, 280],
        "ray2End": [550, 150],
        "showArc": true,
        "showMeasurement": true,
        "arcRadius": 60,
        "style": { "stroke": "#fbbf24", "strokeWidth": 2 }
      },
      {
        "id": "ray-endpoint",
        "type": "point",
        "position": [550, 150],
        "radius": 12,
        "label": "",
        "draggable": true,
        "style": { "fill": "#7c3aed", "stroke": "#a78bfa", "strokeWidth": 2 }
      },
      {
        "id": "tick-0",
        "type": "annotation",
        "position": [590, 295],
        "latex": "0°",
        "anchor": "center",
        "style": { "fontSize": 12, "fill": "#94a3b8" }
      },
      {
        "id": "tick-90",
        "type": "annotation",
        "position": [400, 90],
        "latex": "90°",
        "anchor": "center",
        "style": { "fontSize": 12, "fill": "#94a3b8" }
      },
      {
        "id": "tick-180",
        "type": "annotation",
        "position": [210, 295],
        "latex": "180°",
        "anchor": "center",
        "style": { "fontSize": 12, "fill": "#94a3b8" }
      },
      {
        "id": "angle-type-label",
        "type": "annotation",
        "position": [400, 460],
        "latex": "\\text{Acute Angle}",
        "anchor": "center",
        "style": { "fontSize": 24, "fill": "#10b981" },
        "opacity": 0
      },
      {
        "id": "angle-types-legend",
        "type": "group",
        "opacity": 0,
        "children": [
          {
            "id": "legend-acute",
            "type": "annotation",
            "position": [100, 460],
            "latex": "\\text{Acute: } 0°\\text{-}90°",
            "anchor": "center",
            "style": { "fontSize": 13, "fill": "#10b981" }
          },
          {
            "id": "legend-right",
            "type": "annotation",
            "position": [260, 460],
            "latex": "\\text{Right: } 90°",
            "anchor": "center",
            "style": { "fontSize": 13, "fill": "#fbbf24" }
          },
          {
            "id": "legend-obtuse",
            "type": "annotation",
            "position": [400, 460],
            "latex": "\\text{Obtuse: } 90°\\text{-}180°",
            "anchor": "center",
            "style": { "fontSize": 13, "fill": "#ef4444" }
          },
          {
            "id": "legend-straight",
            "type": "annotation",
            "position": [560, 460],
            "latex": "\\text{Straight: } 180°",
            "anchor": "center",
            "style": { "fontSize": 13, "fill": "#94a3b8" }
          },
          {
            "id": "legend-reflex",
            "type": "annotation",
            "position": [710, 460],
            "latex": "\\text{Reflex: } 180°\\text{-}360°",
            "anchor": "center",
            "style": { "fontSize": 13, "fill": "#7c3aed" }
          }
        ]
      }
    ],
    "animations": [
      {
        "id": "spatial-intro",
        "trigger": "stage-enter",
        "steps": [
          {
            "action": "fadeIn",
            "target": "protractor-arc",
            "duration": 0.5,
            "ease": "easeInOut"
          },
          {
            "action": "draw",
            "target": "ray-fixed",
            "duration": 0.5,
            "ease": "easeInOut"
          },
          {
            "action": "draw",
            "target": "ray-draggable-line",
            "duration": 0.8,
            "ease": "easeInOut"
          },
          {
            "action": "fadeIn",
            "target": "angle-arc",
            "duration": 0.5,
            "ease": "easeInOut"
          },
          {
            "action": "fadeIn",
            "target": "ray-endpoint",
            "duration": 0.4,
            "ease": "spring",
            "from": "scale"
          },
          { "action": "wait", "duration": 0.3 },
          {
            "action": "fadeIn",
            "target": "angle-type-label",
            "duration": 0.5,
            "ease": "easeInOut"
          },
          {
            "action": "fadeIn",
            "target": "angle-types-legend",
            "duration": 0.5,
            "ease": "easeInOut"
          }
        ]
      }
    ],
    "interactions": [
      {
        "id": "drag-ray",
        "type": "drag",
        "target": "ray-endpoint",
        "onUpdate": [
          {
            "source": "angle",
            "target": "angle-arc",
            "property": "ray2End",
            "transform": "updateAngleFromDrag(400, 280)"
          },
          {
            "source": "angle",
            "target": "ray-draggable-line",
            "property": "to",
            "transform": "updateLineEndFromDrag(400, 280)"
          },
          {
            "source": "angle",
            "target": "angle-type-label",
            "property": "latex",
            "transform": "classifyAngle()"
          }
        ]
      }
    ]
  },
